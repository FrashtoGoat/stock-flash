# ===== 密钥 (仅放 API Key / 密码，非密钥配置放 settings.yaml) =====

# 阿里百炼
BAILIAN_API_KEY=your_bailian_api_key_here

# 智谱 AI
ZHIPU_API_KEY=your_zhipu_api_key_here
# 自部署时取消注释并修改（默认使用官方地址，见 settings.yaml）：
# ZHIPU_BASE_URL=http://your-autodl-host:8000/v1

# 邮件通知（QQ 邮箱：发件人填本邮箱，密码填 QQ 邮箱「授权码」）
EMAIL_SENDER=1271573554@qq.com
EMAIL_PASSWORD=你的QQ邮箱授权码
# 收件人已在 settings.yaml 中写为 1271573554@qq.com，可改

# PushPlus 已关闭，改用邮箱
# PUSHPLUS_TOKEN=your_pushplus_token

# OpenCTP 仿真/7x24（trading.mode=ctp 时使用）
# OPENCTP_USER=你的仿真或7x24账号
# OPENCTP_PASSWORD=你的密码
